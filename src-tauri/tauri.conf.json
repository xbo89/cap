{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenCap",
  "version": "0.1.0",
  "identifier": "com.master.screencap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "ScreenCap",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 13, "y": 9 },
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["capcap"],
        "name": "ScreenCap Project",
        "description": "ScreenCap Project",
        "role": "Editor",
        "mimeType": "application/x-capcap",
        "exportedType": {
          "identifier": "com.master.screencap.project",
          "conformsTo": ["com.apple.package"]
        }
      }
    ],
    "macOS": {
      "files": {
        "Resources/capcap-doc.icns": "icons/capcap-doc.icns"
      }
    }
  }
}
